{
  "buildCommand": "npm run build",
  "outputDirectory": "dist/server",
  "installCommand": "npm install",
  "framework": null,
  "functions": {
    "dist/server/server.js": {
      "runtime": "nodejs22.x"
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/dist/server/server.js"
    }
  ]
}
